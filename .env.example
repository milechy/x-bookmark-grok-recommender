# Slack App Credentials
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
# 省略可。Edge→Node 内部呼び出し用。未設定時は SLACK_SIGNING_SECRET を使う
# SLACK_WORKER_SECRET=long-random-string
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# X (Twitter) OAuth2 App Credentials (for User Context OAuth)
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
# Note: X App must have bookmark.read scope enabled and be set to "Native App" or have proper redirect URIs

# xAI Grok API
GROK_API_KEY=gsk_your_grok_api_key_here
# 省略時は grok-4.20-reasoning
# GROK_MODEL=grok-4.20-reasoning

# Vercel KV for production (recommended)
VERCEL_KV_REST_API_URL=https://your-kv.vercel-storage.com
VERCEL_KV_REST_API_TOKEN=your-vercel-kv-token

# Optional: For local development fallback (SQLite)
# SQLITE_DB_PATH=./data/bookmarks.db

# Optional: For local testing
PORT=3000
NODE_ENV=development

# Optional: Sentry or logging
# SENTRY_DSN=your-sentry-dsn
