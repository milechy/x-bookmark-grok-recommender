# Slack App Credentials
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
# 省略可。Edge→Node 内部呼び出し用。未設定時は SLACK_SIGNING_SECRET を使う
# SLACK_WORKER_SECRET=long-random-string
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# X (Twitter) OAuth2 App Credentials (for User Context OAuth)
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
# Note: X App must have bookmark.read scope enabled and be set to "Native App" or have proper redirect URIs

# xAI Grok API
GROK_API_KEY=gsk_your_grok_api_key_here
# 省略時は grok-4.20-reasoning
# GROK_MODEL=grok-4.20-reasoning
# 1 のとき Grok 失敗時にキーワード類似で代替（本番は未設定推奨＝失敗を Slack 通知）
# GROK_ALLOW_KEYWORD_FALLBACK=1

# Vercel KV for production (recommended)
VERCEL_KV_REST_API_URL=https://your-kv.vercel-storage.com
VERCEL_KV_REST_API_TOKEN=your-vercel-kv-token

# Optional: For local development fallback (SQLite)
# SQLITE_DB_PATH=./data/bookmarks.db

# Optional: For local testing
PORT=3000
NODE_ENV=development

# /api/logs ブラウザ閲覧用トークン（必須）。未設定だと /api/logs は 503 を返す
# 例: openssl rand -hex 24 で適当に生成
LOGS_ACCESS_TOKEN=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# FounderOS v2: Obsidian 連携
# ---------------------------------------------------------------------------
# 動作モードは以下の優先度で自動選択される:
#   1. github : OBSIDIAN_GITHUB_REPO + OBSIDIAN_GITHUB_TOKEN が両方ある
#   2. local  : OBSIDIAN_VAULT_PATH が設定 ＆ ローカル実行（!process.env.VERCEL）
#   3. slack-upload : 上記いずれもなし → .md を Slack DM にアップロード
#
# Vercel 本番から Obsidian vault に直接書きたい場合は github モード推奨。
# Obsidian Git plugin で vault リポジトリを pull してください。

# [local モード用] Obsidian vault のローカル絶対パス（ローカル実行時のみ有効）
# OBSIDIAN_VAULT_PATH=/Users/you/Documents/Obsidian/MyVault

# [github モード用] vault リポジトリ。形式 "owner/repo"
# OBSIDIAN_GITHUB_REPO=your-username/obsidian-vault
# 必要スコープ: contents:write
# OBSIDIAN_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx
# 任意（デフォルト main）
# OBSIDIAN_GITHUB_BRANCH=main
# 任意（commit author 表記）
# OBSIDIAN_GITHUB_AUTHOR=FounderOS Bot
# OBSIDIAN_GITHUB_EMAIL=founderos-bot@noreply.local

# [共通] vault 内の保存先フォルダ（デフォルト 00_Inbox/X-Bookmarks）
# OBSIDIAN_NOTE_FOLDER=00_Inbox/X-Bookmarks

# ---------------------------------------------------------------------------
# FounderOS v2: 生成モード（事業アイデア合成）
# ---------------------------------------------------------------------------
# 1 で有効化。デフォルト OFF。現状はスタブのみ（次フェーズで Grok 接続）
# ENABLE_GENERATION_MODE=0

# Optional: Sentry or logging
# SENTRY_DSN=your-sentry-dsn
